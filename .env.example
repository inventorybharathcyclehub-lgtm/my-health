# Copy to .env.local and fill in. Vercel will inject these automatically in prod.
# Prisma Postgres (Accelerate) URL from Vercel Storage tab
DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=..."

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Prayer times
ALADHAN_BASE_URL="https://api.aladhan.com/v1"

# Cron secret (Vercel will read this header)
CRON_SECRET=""
